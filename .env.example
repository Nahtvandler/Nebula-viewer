# --- Подключение к NebulaGraph ---
# По умолчанию — контейнер graphd из rsm-extractor в его же сети.
NEBULA_HOST=nebula-graphd
NEBULA_PORT=9669
NEBULA_USER=root
NEBULA_PASSWORD=nebula
NEBULA_SPACE=rsm_graph_poc

# Внешняя docker-сеть, в которой живёт nebula-graphd.
# Имя = <папка_проекта>_<имя_сети>. Для rsm-extractor это обычно:
NEBULA_NETWORK=rsm-extractor_default

# --- Порты на хосте ---
FRONTEND_PORT=8080
BACKEND_PORT=8010

# CORS: список origin через запятую или * (для локальной разработки)
CORS_ORIGINS=*

# --- Вариант без общей сети (Nebula на хосте / другой сети) ---
# Закомментируйте блок networks в docker-compose.yml (external),
# затем укажите адрес graphd, доступный из контейнера:
#   NEBULA_HOST=host.docker.internal
#   NEBULA_PORT=9669
